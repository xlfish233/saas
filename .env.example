# Server Configuration
SERVER__HOST=0.0.0.0
SERVER__PORT=8080
SERVER__ENVIRONMENT=local

# Database
DATABASE__URL=postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/YOUR_DB
DATABASE__POOL_SIZE=10

# Redis
REDIS__URL=redis://localhost:6379

# NATS
NATS__URL=nats://localhost:4222

# JWT Configuration
JWT__PRIVATE_KEY_PATH=keys/private.pem
JWT__PUBLIC_KEY_PATH=keys/public.pem
JWT__ISSUER=erp-saas
JWT__AUDIENCE=erp-saas-api
JWT__ACCESS_TOKEN_EXPIRY_SECONDS=900
JWT__REFRESH_TOKEN_EXPIRY_SECONDS=604800

# CORS (comma-separated origins)
CORS__ORIGINS=http://localhost:3000,http://localhost:5173

# AWS (for local development with LocalStack/MinIO)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000

# Telemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
RUST_LOG=info,erp_saas=debug
